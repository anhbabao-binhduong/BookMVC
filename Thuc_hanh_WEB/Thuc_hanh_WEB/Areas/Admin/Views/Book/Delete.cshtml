@model Thuc_hanh_WEB.Models.Book
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Xóa Sách";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">
        <div class="card border-danger shadow-lg">
            <div class="card-header bg-danger text-white py-3">
                <h4 class="mb-0 fw-bold"><i class="fas fa-exclamation-triangle me-2"></i> Xác Yêu Cầu Xóa</h4>
            </div>
            <div class="card-body p-4 text-center">
                <div class="mb-4">
                    <img src="@Model.CoverImage" class="rounded shadow border" style="height: 120px; object-fit: cover;" onerror="this.src='/Content/images/no-image.png'" alt="Cover" />
                </div>
                <h4 class="fw-bold mb-3">@Model.Title</h4>
                <p class="text-muted mb-4">Bạn đang thực hiện thao tác xóa vĩnh viễn dữ liệu về cuốn sách này ra khỏi hệ thống cơ sở dữ liệu.</p>
                
                <div class="alert alert-warning border-warning" role="alert">
                    <i class="fas fa-info-circle me-1"></i> <strong>Lưu ý:</strong> Hành động này không thể hoàn tác lại được!
                </div>

                @using (Html.BeginForm("Delete", "Book", new { id = Model.BookID }, FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <div class="d-flex justify-content-center gap-3 mt-4">
                        <a href="@Url.Action("Index")" class="btn btn-light border px-4">Quay lại (Hủy bỏ)</a>
                        <button type="submit" class="btn btn-danger px-4 fw-bold"><i class="fas fa-trash-alt me-2"></i> Xóa vĩnh viễn sách</button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
@model IEnumerable<Thuc_hanh_WEB.Models.Book>
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Quản lý Sách";
}

<style>
    .page-header-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: .75rem;
    }

    .admin-table-card {
        border-radius: 12px;
        border: 1px solid #ebebf0;
        overflow: hidden;
        box-shadow: 0 1px 6px rgba(0,0,0,.06);
    }

    .admin-table-card .card-header {
        background: #fff;
        border-bottom: 1px solid #ebebf0;
        padding: .85rem 1.25rem;
    }

    /* Mobile card layout */
    .book-mobile-card {
        display: none;
    }

    @@media (max-width: 767.98px) {
        .book-desktop-table { display: none !important; }
        .book-mobile-card  { display: block; }

        .book-item-card {
            background: #fff;
            border: 1px solid #e8e8f0;
            border-radius: 10px;
            padding: .9rem 1rem;
            margin-bottom: .75rem;
            display: flex;
            gap: .85rem;
            align-items: flex-start;
            box-shadow: 0 1px 4px rgba(0,0,0,.05);
        }

        .book-item-card img {
            width: 52px;
            height: 74px;
            object-fit: cover;
            border-radius: 6px;
            flex-shrink: 0;
        }

        .book-item-info {
            flex: 1;
            min-width: 0;
        }

        .book-item-title {
            font-weight: 600;
            font-size: 14px;
            color: #1a1a2e;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-bottom: 3px;
        }

        .book-item-meta {
            font-size: 12px;
            color: #888;
            margin-bottom: 2px;
        }

        .book-item-price {
            font-size: 13px;
            font-weight: 700;
            color: #dc3545;
            margin-bottom: 5px;
        }

        .book-item-actions {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
            margin-top: 6px;
        }
    }

    @@media (min-width: 768px) {
        .book-desktop-table { display: block !important; }
    }
</style>

<div class="card admin-table-card border-0 mt-3">
    <div class="card-header">
        <div class="page-header-bar">
            <h4 class="mb-0 text-primary"><i class="fas fa-book me-2"></i>Danh sách sách</h4>
            <a href="@Url.Action("Create")" class="btn btn-primary shadow-sm">
                <i class="fas fa-plus me-1"></i> Thêm Sách
            </a>
        </div>
    </div>

    <div class="card-body p-0">
        @if (Model == null || !Model.Any())
        {
            <div class="p-5 text-center">
                <i class="fas fa-book-open fa-3x text-muted mb-3 opacity-50"></i>
                <h5 class="text-muted">Chưa có sách nào</h5>
            </div>
        }
        else
        {
            /* ========= DESKTOP TABLE ========= */
            <div class="table-responsive book-desktop-table">
                <table class="table table-hover table-striped mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Ảnh bìa</th>
                            <th>Tiêu đề sách</th>
                            <th>Giá bán</th>
                            <th class="d-none d-lg-table-cell">Tác giả</th>
                            <th class="d-none d-xl-table-cell">Danh mục</th>
                            <th class="d-none d-xl-table-cell">NXB</th>
                            <th>Tồn kho</th>
                            <th class="text-center pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-secondary">#@item.BookID</td>
                                <td>
                                    <img src="@item.CoverImage" class="rounded shadow-sm" style="width:50px;height:75px;object-fit:cover;" onerror="this.src='/Content/images/no-image.png'" alt="Cover" />
                                </td>
                                <td class="fw-semibold text-dark" style="max-width:220px;">@item.Title</td>
                                <td class="text-danger fw-bold text-nowrap">@String.Format("{0:N0} đ", item.Price)</td>
                                <td class="text-muted d-none d-lg-table-cell">@(item.Author?.Name ?? "-")</td>
                                <td class="d-none d-xl-table-cell"><span class="badge bg-info text-dark bg-opacity-25 border border-info">@(item.Category?.CategoryName ?? "-")</span></td>
                                <td class="text-muted d-none d-xl-table-cell">@(item.Publisher?.Name ?? "-")</td>
                                <td>
                                    @if (item.Stock > 10)
                                    {
                                        <span class="badge bg-success bg-opacity-75">@item.Stock</span>
                                    }
                                    else if (item.Stock > 0)
                                    {
                                        <span class="badge bg-warning text-dark">@item.Stock</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Hết</span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <div class="btn-group shadow-sm" role="group">
                                        <a href="@Url.Action("Details", new { id = item.BookID })" class="btn btn-sm btn-outline-info" title="Xem chi tiết"><i class="fas fa-eye"></i></a>
                                        <a href="@Url.Action("Edit", new { id = item.BookID })" class="btn btn-sm btn-outline-primary" title="Chỉnh sửa"><i class="fas fa-edit"></i></a>
                                        <a href="@Url.Action("Delete", new { id = item.BookID })" class="btn btn-sm btn-outline-danger" title="Xóa"><i class="fas fa-trash-alt"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            /* ========= MOBILE CARDS ========= */
            <div class="book-mobile-card p-3">
                @foreach (var item in Model)
                {
                    <div class="book-item-card">
                        <img src="@item.CoverImage" onerror="this.src='/Content/images/no-image.png'" alt="Cover" />
                        <div class="book-item-info">
                            <div class="book-item-title">@item.Title</div>
                            <div class="book-item-meta">@(item.Author?.Name ?? "-") &bull; @(item.Category?.CategoryName ?? "-")</div>
                            <div class="book-item-price">@String.Format("{0:N0} đ", item.Price)</div>
                            <div class="mb-1">
                                @if (item.Stock > 10)
                                {
                                    <span class="badge bg-success bg-opacity-75">Còn @item.Stock</span>
                                }
                                else if (item.Stock > 0)
                                {
                                    <span class="badge bg-warning text-dark">Còn @item.Stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Hết hàng</span>
                                }
                            </div>
                            <div class="book-item-actions">
                                <a href="@Url.Action("Details", new { id = item.BookID })" class="btn btn-sm btn-outline-info"><i class="fas fa-eye me-1"></i>Xem</a>
                                <a href="@Url.Action("Edit", new { id = item.BookID })" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit me-1"></i>Sửa</a>
                                <a href="@Url.Action("Delete", new { id = item.BookID })" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash-alt me-1"></i>Xóa</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
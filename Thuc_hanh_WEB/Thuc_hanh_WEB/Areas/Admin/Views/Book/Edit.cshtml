@model Thuc_hanh_WEB.Models.Book
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Cập nhật Sách";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-10">
        <div class="card shadow border-0 rounded-3">
            <div class="card-header bg-white border-bottom py-3">
                <h4 class="mb-0 text-primary"><i class="fas fa-edit me-2"></i>Cập nhật thông tin Sách</h4>
            </div>
            <div class="card-body p-4">
                @using (Html.BeginForm("Edit", "Book", FormMethod.Post, new { enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.BookID)
                    
                    <div class="row gx-5">
                        <!-- Cột Trái -->
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Tiêu đề sách <span class="text-danger">*</span></label>
                                @Html.TextBoxFor(m => m.Title, new { @class = "form-control", placeholder = "Nhập tiêu đề sách..." })
                                @Html.ValidationMessageFor(m => m.Title, "", new { @class = "text-danger small" })
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Giá bán (VNĐ) <span class="text-danger">*</span></label>
                                @Html.TextBoxFor(m => m.Price, "{0:0}", new { @class = "form-control", type = "number", placeholder = "Ví dụ: 150000" })
                                @Html.ValidationMessageFor(m => m.Price, "", new { @class = "text-danger small" })
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Số lượng tồn kho <span class="text-danger">*</span></label>
                                @Html.TextBoxFor(m => m.Stock, new { @class = "form-control", type = "number", placeholder = "Nhập số lượng..." })
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Mã ISBN</label>
                                @Html.TextBoxFor(m => m.ISBN, new { @class = "form-control", placeholder = "Mã số tiêu chuẩn quốc tế sách..." })
                            </div>
                        </div>

                        <!-- Cột Phải -->
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Tác giả</label>
                                @Html.DropDownList("AuthorID", null, "-- Chọn tác giả --", new { @class = "form-select" })
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Danh mục</label>
                                @Html.DropDownList("CategoryID", null, "-- Chọn danh mục --", new { @class = "form-select" })
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Nhà xuất bản</label>
                                @Html.DropDownList("PublisherID", null, "-- Chọn NXB --", new { @class = "form-select" })
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Ảnh bìa sách (Để trống nếu không đổi)</label>
                                <input type="file" name="CoverImageFile" class="form-control mb-2" accept="image/*" />
                                @if (!string.IsNullOrEmpty(Model.CoverImage))
                                {
                                    <div class="d-flex align-items-center bg-light p-2 rounded border">
                                        <span class="me-3 small text-muted">Ảnh hiện tại:</span>
                                        <img src="@Model.CoverImage" class="rounded shadow-sm" style="height: 70px; object-fit: cover;" onerror="this.src='/Content/images/no-image.png'" alt="Current Cover" />
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-4 mt-2">
                        <label class="form-label fw-semibold">Mô tả chi tiết</label>
                        @Html.TextAreaFor(m => m.Description, new { @class = "form-control", rows = 5, placeholder = "Nhập tóm tắt hoặc mô tả nội dung cuốn sách..." })
                    </div>

                    <div class="d-flex justify-content-end gap-2 border-top pt-3">
                        <a href="@Url.Action("Index")" class="btn btn-light border px-4">Quay lại</a>
                        <button type="submit" class="btn btn-primary px-4"><i class="fas fa-save me-1"></i> Cập nhật Sách</button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
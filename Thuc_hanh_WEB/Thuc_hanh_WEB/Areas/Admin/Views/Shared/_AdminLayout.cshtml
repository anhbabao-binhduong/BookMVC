<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - BookStore Admin</title>

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <!-- Font Awesome 5 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <style>
        :root {
            --sidebar-width: 260px;
            --sidebar-bg: #1a2332;
            --sidebar-text: #c8cfd8;
            --sidebar-hover: #243042;
            --sidebar-active: #2e3f55;
            --sidebar-accent: #c9a84c;
            --topbar-height: 64px;
            --content-bg: #f0f2f5;
            --card-bg: #ffffff;
            --text-primary: #1a2332;
            --text-secondary: #6c757d;
            --border-color: #e8ecf0;
            --primary-color: #2563eb;
            --success-color: #16a34a;
            --warning-color: #d97706;
            --danger-color: #dc2626;
        }

        * {
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--content-bg);
            color: var(--text-primary);
            margin: 0;
            padding: 0;
        }

        /* ===== SIDEBAR ===== */
        .admin-sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: var(--sidebar-width);
            height: 100vh;
            background: var(--sidebar-bg);
            z-index: 1050;
            overflow-y: auto;
            overflow-x: hidden;
            transition: transform 0.3s ease;
            display: flex;
            flex-direction: column;
        }

        .admin-sidebar::-webkit-scrollbar {
            width: 4px;
        }

        .admin-sidebar::-webkit-scrollbar-track {
            background: transparent;
        }

        .admin-sidebar::-webkit-scrollbar-thumb {
            background: #3a4d63;
            border-radius: 4px;
        }

        /* Sidebar Brand */
        .sidebar-brand {
            padding: 20px 20px 16px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            flex-shrink: 0;
        }

        .sidebar-brand-icon {
            width: 42px;
            height: 42px;
            background: linear-gradient(135deg, var(--sidebar-accent), #e8c06a);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: #fff;
            flex-shrink: 0;
            box-shadow: 0 4px 12px rgba(201, 168, 76, 0.4);
        }

        .sidebar-brand-text {
            display: flex;
            flex-direction: column;
        }

        .sidebar-brand-title {
            font-size: 15px;
            font-weight: 700;
            color: #ffffff;
            letter-spacing: 0.3px;
            line-height: 1.2;
        }

        .sidebar-brand-sub {
            font-size: 11px;
            color: var(--sidebar-accent);
            font-weight: 500;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        /* Sidebar Nav */
        .sidebar-nav {
            padding: 12px 0;
            flex: 1;
        }

        .nav-section-label {
            padding: 10px 20px 6px;
            font-size: 10.5px;
            font-weight: 600;
            color: #5a6a7e;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .sidebar-nav .nav-item {
            margin: 2px 10px;
        }

        .sidebar-nav .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            color: var(--sidebar-text);
            font-size: 14px;
            font-weight: 500;
            border-radius: 8px;
            text-decoration: none;
            transition: all 0.2s ease;
            position: relative;
        }

        .sidebar-nav .nav-link:hover {
            background: var(--sidebar-hover);
            color: #ffffff;
            transform: translateX(2px);
        }

        .sidebar-nav .nav-link.active {
            background: linear-gradient(135deg, #2e3f55, #243042);
            color: #ffffff;
            box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        }

        .sidebar-nav .nav-link.active::before {
            content: '';
            position: absolute;
            left: 0;
            top: 50%;
            transform: translateY(-50%);
            width: 3px;
            height: 24px;
            background: var(--sidebar-accent);
            border-radius: 0 3px 3px 0;
        }

        .sidebar-nav .nav-link .nav-icon {
            width: 20px;
            height: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
            flex-shrink: 0;
        }

        .sidebar-nav .nav-link.active .nav-icon {
            color: var(--sidebar-accent);
        }

        .sidebar-nav .nav-link:hover .nav-icon {
            color: var(--sidebar-accent);
        }

        /* Sidebar Footer */
        .sidebar-footer {
            padding: 12px 10px;
            border-top: 1px solid rgba(255,255,255,0.07);
            flex-shrink: 0;
        }

        .sidebar-footer .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            color: #8a9bb0;
            font-size: 14px;
            font-weight: 500;
            border-radius: 8px;
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .sidebar-footer .nav-link:hover {
            background: rgba(220, 38, 38, 0.15);
            color: #f87171;
        }

        /* ===== TOP NAVBAR ===== */
        .admin-topbar {
            position: fixed;
            top: 0;
            left: var(--sidebar-width);
            right: 0;
            height: var(--topbar-height);
            background: #ffffff;
            border-bottom: 1px solid var(--border-color);
            z-index: 1040;
            display: flex;
            align-items: center;
            padding: 0 28px;
            justify-content: space-between;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .topbar-page-title {
            font-size: 18px;
            font-weight: 600;
            color: var(--text-primary);
            margin: 0;
        }

        .topbar-breadcrumb {
            font-size: 12.5px;
            color: var(--text-secondary);
            margin: 0;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .topbar-btn {
            width: 38px;
            height: 38px;
            border: 1.5px solid var(--border-color);
            border-radius: 9px;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-secondary);
            cursor: pointer;
            transition: all 0.2s ease;
            text-decoration: none;
            font-size: 15px;
        }

        .topbar-btn:hover {
            border-color: var(--sidebar-accent);
            color: var(--sidebar-accent);
            background: rgba(201, 168, 76, 0.08);
        }

        .topbar-admin-info {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 6px 14px 6px 8px;
            border: 1.5px solid var(--border-color);
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.2s ease;
            text-decoration: none;
        }

        .topbar-admin-info:hover {
            border-color: var(--sidebar-accent);
            background: rgba(201, 168, 76, 0.05);
        }

        .topbar-avatar {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            background: linear-gradient(135deg, #1a2332, #2e3f55);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--sidebar-accent);
            font-size: 14px;
            font-weight: 700;
        }

        .topbar-name {
            font-size: 13.5px;
            font-weight: 600;
            color: var(--text-primary);
        }

        .topbar-role {
            font-size: 11px;
            color: var(--text-secondary);
        }

        /* ===== MAIN CONTENT ===== */
        .admin-main {
            margin-left: var(--sidebar-width);
            margin-top: var(--topbar-height);
            min-height: calc(100vh - var(--topbar-height));
            padding: 28px;
        }

        /* ===== CARDS ===== */
        .stat-card {
            background: var(--card-bg);
            border-radius: 14px;
            padding: 24px;
            border: 1px solid var(--border-color);
            transition: all 0.25s ease;
            position: relative;
            overflow: hidden;
        }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.1);
            border-color: transparent;
        }

        .stat-card::after {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 80px;
            height: 80px;
            border-radius: 50%;
            opacity: 0.07;
        }

        .stat-card .stat-icon {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            margin-bottom: 16px;
        }

        .stat-card .stat-value {
            font-size: 26px;
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1.2;
            margin-bottom: 4px;
        }

        .stat-card .stat-label {
            font-size: 13px;
            color: var(--text-secondary);
            font-weight: 500;
        }

        /* ===== TABLE STYLES ===== */
        .admin-table-card {
            background: var(--card-bg);
            border-radius: 14px;
            border: 1px solid var(--border-color);
            overflow: hidden;
        }

        .admin-table-card .card-header-custom {
            padding: 18px 24px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .admin-table-card .card-header-custom h5 {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-primary);
            margin: 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .table > thead > tr > th {
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-secondary);
            border-bottom-width: 1px;
            background: #f8fafc;
            padding: 12px 16px;
        }

        .table > tbody > tr > td {
            padding: 14px 16px;
            vertical-align: middle;
            font-size: 13.5px;
            border-bottom: 1px solid var(--border-color);
        }

        .table > tbody > tr:last-child > td {
            border-bottom: none;
        }

        .table > tbody > tr {
            transition: background 0.15s ease;
        }

        .table > tbody > tr:hover {
            background: #f8fafc;
        }

        /* ===== FORM STYLES ===== */
        .form-control, .form-select {
            border: 1.5px solid var(--border-color);
            border-radius: 8px;
            font-size: 14px;
            padding: 9px 14px;
            transition: all 0.2s ease;
            color: var(--text-primary);
        }

        .form-control:focus, .form-select:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.12);
        }

        .form-label {
            font-size: 13.5px;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 6px;
        }

        /* ===== BUTTON STYLES ===== */
        .btn {
            font-size: 13.5px;
            font-weight: 500;
            border-radius: 8px;
            padding: 9px 18px;
            transition: all 0.2s ease;
        }

        .btn-primary {
            background: #2563eb;
            border-color: #2563eb;
        }

        .btn-primary:hover {
            background: #1d4ed8;
            border-color: #1d4ed8;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
        }

        .btn-success {
            background: #16a34a;
            border-color: #16a34a;
        }

        .btn-success:hover {
            background: #15803d;
            border-color: #15803d;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(22, 163, 74, 0.3);
        }

        .btn-danger {
            background: #dc2626;
            border-color: #dc2626;
        }

        .btn-danger:hover {
            background: #b91c1c;
            border-color: #b91c1c;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(220, 38, 38, 0.3);
        }

        .btn-sm {
            padding: 6px 12px;
            font-size: 12.5px;
            border-radius: 7px;
        }

        /* ===== BADGE STYLES ===== */
        .badge {
            font-size: 11.5px;
            font-weight: 600;
            padding: 5px 10px;
            border-radius: 6px;
            letter-spacing: 0.2px;
        }

        /* ===== PAGE HEADER ===== */
        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 24px;
        }

        .page-header-title {
            font-size: 22px;
            font-weight: 700;
            color: var(--text-primary);
            margin: 0;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .page-header-icon {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            background: linear-gradient(135deg, #1a2332, #2e3f55);
            color: var(--sidebar-accent);
        }

        /* ===== CARD GENERIC ===== */
        .admin-card {
            background: var(--card-bg);
            border-radius: 14px;
            border: 1px solid var(--border-color);
        }

        .admin-card .admin-card-header {
            padding: 18px 24px;
            border-bottom: 1px solid var(--border-color);
        }

        .admin-card .admin-card-body {
            padding: 24px;
        }

        /* ===== ALERT STYLES ===== */
        .alert {
            border-radius: 10px;
            border: none;
            font-size: 14px;
            padding: 14px 18px;
        }

        /* ===== RESPONSIVE ===== */
        @@media (max-width: 991px) {
            .admin-sidebar {
                transform: translateX(-100%);
            }

            .admin-sidebar.show {
                transform: translateX(0);
            }

            .admin-topbar {
                left: 0;
            }

            .admin-main {
                margin-left: 0;
            }

            .admin-footer {
                margin-left: 0 !important;
            }
        }

        /* ===== INPUT GROUP ===== */
        .input-group-text {
            background: #f8fafc;
            border: 1.5px solid var(--border-color);
            color: var(--text-secondary);
            font-size: 14px;
        }

        /* ===== SCROLLBAR ===== */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: #f1f5f9;
        }

        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 3px;
        }

        /* ===== PAGE FADE IN ===== */
        .admin-main {
            animation: pageFadeIn 0.3s ease;
        }

        @@keyframes pageFadeIn {
            from {
                opacity: 0;
                transform: translateY(8px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Active link detection helpers */
        .nav-link-wrapper {
            display: block;
        }
    </style>

    @RenderSection("styles", required: false)
</head>
<body>
    <!-- ===== SIDEBAR ===== -->
    <aside class="admin-sidebar" id="adminSidebar">
        <!-- Brand -->
        <a href="@Url.Action("Index", "Home", new { area = "Admin" })" class="sidebar-brand">
            <div class="sidebar-brand-icon">
                <i class="fas fa-book-open"></i>
            </div>
            <div class="sidebar-brand-text">
                <span class="sidebar-brand-title">BookStore</span>
                <span class="sidebar-brand-sub">Admin Panel</span>
            </div>
        </a>

        <!-- Navigation -->
        <nav class="sidebar-nav">
            <!-- Main -->
            <div class="nav-section-label">Tổng quan</div>
            <ul class="nav flex-column" style="list-style: none; padding: 0; margin: 0;">
                <li class="nav-item">
                    <a href="@Url.Action("Index", "Home", new { area = "Admin" })"
                       class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Home" ? "active" : "")">
                        <span class="nav-icon"><i class="fas fa-tachometer-alt"></i></span>
                        <span>Dashboard</span>
                    </a>
                </li>
            </ul>

            <!-- Catalogue -->
            <div class="nav-section-label" style="margin-top: 8px;">Danh mục sản phẩm</div>
            <ul class="nav flex-column" style="list-style: none; padding: 0; margin: 0;">
                <li class="nav-item">
                    <a href="@Url.Action("Index", "Book", new { area = "Admin" })"
                       class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Book" ? "active" : "")">
                        <span class="nav-icon"><i class="fas fa-book"></i></span>
                        <span>Quản lý Sách</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="@Url.Action("Index", "Category", new { area = "Admin" })"
                       class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Category" ? "active" : "")">
                        <span class="nav-icon"><i class="fas fa-tags"></i></span>
                        <span>Danh mục</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="@Url.Action("Index", "Author", new { area = "Admin" })"
                       class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Author" ? "active" : "")">
                        <span class="nav-icon"><i class="fas fa-feather-alt"></i></span>
                        <span>Tác giả</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="@Url.Action("Index", "Publisher", new { area = "Admin" })"
                       class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Publisher" ? "active" : "")">
                        <span class="nav-icon"><i class="fas fa-building"></i></span>
                        <span>Nhà xuất bản</span>
                    </a>
                </li>
            </ul>

            <!-- Sales -->
            <div class="nav-section-label" style="margin-top: 8px;">Bán hàng</div>
            <ul class="nav flex-column" style="list-style: none; padding: 0; margin: 0;">
                <li class="nav-item">
                    <a href="@Url.Action("Index", "Order", new { area = "Admin" })"
                       class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Order" ? "active" : "")">
                        <span class="nav-icon"><i class="fas fa-shopping-bag"></i></span>
                        <span>Đơn hàng</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="@Url.Action("Index", "Coupon", new { area = "Admin" })"
                       class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Coupon" ? "active" : "")">
                        <span class="nav-icon"><i class="fas fa-ticket-alt"></i></span>
                        <span>Mã giảm giá</span>
                    </a>
                </li>
            </ul>
        </nav>

        <!-- Sidebar Footer -->
        <div class="sidebar-footer">
            <a href="@Url.Action("Logout", "Auth", new { area = "Admin" })" class="nav-link"
               onclick="return confirm('Bạn có chắc muốn đăng xuất?')">
                <span class="nav-icon"><i class="fas fa-sign-out-alt"></i></span>
                <span>Đăng xuất</span>
            </a>
        </div>
    </aside>

    <!-- ===== TOP NAVBAR ===== -->
    <header class="admin-topbar">
        <div class="topbar-left">
            <button class="topbar-btn d-lg-none border-0" id="sidebarToggle" onclick="toggleSidebar()">
                <i class="fas fa-bars"></i>
            </button>
            <div>
                <h1 class="topbar-page-title">@ViewBag.Title</h1>
                <p class="topbar-breadcrumb d-none d-md-flex">
                    <a href="@Url.Action("Index", "Home", new { area = "Admin" })" style="color: inherit; text-decoration: none;">
                        <i class="fas fa-home" style="font-size: 11px;"></i> Trang chủ
                    </a>
                    @if (ViewContext.RouteData.Values["controller"].ToString() != "Home")
                    {
                        <span style="color: #d1d5db;">›</span>
                        <span>@ViewBag.Title</span>
                    }
                </p>
            </div>
        </div>
        <div class="topbar-right">
            <a href="/" target="_blank" class="topbar-btn" title="Xem trang web">
                <i class="fas fa-external-link-alt"></i>
            </a>
            <div class="topbar-admin-info">
                <div class="topbar-avatar">
                    <i class="fas fa-user-shield" style="font-size: 13px;"></i>
                </div>
                <div class="d-none d-sm-block">
                    <div class="topbar-name">@(Session["AdminName"] ?? "Admin")</div>
                    <div class="topbar-role">Administrator</div>
                </div>
            </div>
        </div>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="admin-main">
        @RenderBody()
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="admin-footer" style="margin-left: var(--sidebar-width); padding: 16px 28px; background: #fff; border-top: 1px solid var(--border-color); font-size: 12.5px; color: var(--text-secondary); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
        <span>© 2024 <strong>BookStore Admin</strong>. All rights reserved.</span>
        <span><i class="fas fa-heart me-1" style="color: var(--sidebar-accent);"></i> Hệ thống quản lý bán sách</span>
    </footer>

    <!-- Sidebar overlay for mobile -->
    <div class="d-lg-none" id="sidebarOverlay"
         style="display: none !important; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1049;"
         onclick="toggleSidebar()"></div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <script>
        function toggleSidebar() {
            var sidebar = document.getElementById('adminSidebar');
            var overlay = document.getElementById('sidebarOverlay');
            sidebar.classList.toggle('show');
            if (sidebar.classList.contains('show')) {
                overlay.style.display = 'block !important';
                overlay.style.display = 'block';
            } else {
                overlay.style.display = 'none';
            }
        }

        // Auto-highlight active nav links
        document.addEventListener('DOMContentLoaded', function () {
            // Add smooth transitions to table rows
            var rows = document.querySelectorAll('.table tbody tr');
            rows.forEach(function(row) {
                row.style.transition = 'background-color 0.15s ease';
            });
        });
    </script>

    @RenderSection("scripts", required: false)
</body>
</html>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            background: #0f0f11;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'DM Sans', sans-serif;
            position: relative;
            overflow: hidden;
        }

            body::before {
                content: '';
                position: fixed;
                inset: 0;
                background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
                background-size: 40px 40px;
                pointer-events: none;
            }

        .glow-1 {
            position: fixed;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(83,74,183,0.18) 0%, transparent 70%);
            top: -100px;
            right: -100px;
            pointer-events: none;
        }

        .glow-2 {
            position: fixed;
            width: 280px;
            height: 280px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(29,158,117,0.12) 0%, transparent 70%);
            bottom: -80px;
            left: -80px;
            pointer-events: none;
        }

        .login-card {
            width: 100%;
            max-width: 400px;
            margin: 2rem;
            background: rgba(255,255,255,0.04);
            border: 0.5px solid rgba(255,255,255,0.1);
            border-radius: 16px;
            padding: 2.5rem 2rem;
            position: relative;
            backdrop-filter: blur(10px);
        }

        .admin-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: rgba(83,74,183,0.2);
            border: 0.5px solid rgba(127,119,221,0.4);
            border-radius: 20px;
            padding: 4px 12px;
            font-size: 11px;
            font-weight: 500;
            color: #AFA9EC;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-bottom: 1.25rem;
        }

        .admin-badge-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #7F77DD;
        }

        .login-title {
            font-family: 'DM Serif Display', serif;
            font-size: 28px;
            font-weight: 400;
            color: #f0ede8;
            margin: 0 0 0.3rem;
            line-height: 1.25;
        }

        .login-subtitle {
            font-size: 13px;
            color: rgba(255,255,255,0.35);
            margin: 0 0 2rem;
        }

        .form-label {
            display: block;
            font-size: 11px;
            font-weight: 500;
            color: rgba(255,255,255,0.4);
            letter-spacing: 0.07em;
            text-transform: uppercase;
            margin-bottom: 6px;
        }

        .form-control {
            width: 100%;
            background: rgba(255,255,255,0.05);
            border: 0.5px solid rgba(255,255,255,0.12);
            border-radius: 8px;
            padding: 10px 14px;
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            color: #f0ede8;
            outline: none;
            transition: border-color 0.15s, background 0.15s;
            margin-bottom: 1.25rem;
        }

            .form-control:focus {
                border-color: rgba(127,119,221,0.6);
                background: rgba(127,119,221,0.06);
            }

            .form-control::placeholder {
                color: rgba(255,255,255,0.18);
            }

        .alert-danger {
            background: rgba(226,75,74,0.12);
            border: 0.5px solid rgba(226,75,74,0.3);
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 13px;
            color: #F09595;
            margin-bottom: 1.25rem;
        }

        .btn-login {
            width: 100%;
            background: #7F77DD;
            border: none;
            border-radius: 8px;
            padding: 11px;
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            font-weight: 500;
            color: #fff;
            cursor: pointer;
            transition: background 0.15s, transform 0.1s;
            letter-spacing: 0.02em;
            margin-top: 0.25rem;
        }

            .btn-login:hover {
                background: #534AB7;
            }

            .btn-login:active {
                transform: scale(0.98);
            }

        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 1.75rem 0 1rem;
        }

        .divider-line {
            flex: 1;
            height: 0.5px;
            background: rgba(255,255,255,0.08);
        }

        .divider-text {
            font-size: 11px;
            color: rgba(255,255,255,0.2);
        }

        .login-footer {
            font-size: 11px;
            color: rgba(255,255,255,0.18);
            text-align: center;
            margin-top: 1rem;
            letter-spacing: 0.04em;
        }
    </style>
</head>
<body>
    <div class="glow-1"></div>
    <div class="glow-2"></div>

    <div class="login-card">
        <div class="admin-badge">
            <div class="admin-badge-dot"></div>
            Admin Panel
        </div>

        <h1 class="login-title">Xin chào,<br>hãy đăng nhập</h1>
        <p class="login-subtitle">Dành riêng cho quản trị viên hệ thống</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert-danger">@ViewBag.Error</div>
        }

        @using (Html.BeginForm("Login", "Auth", new { area = "Admin" }, FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" placeholder="admin@example.com" required autofocus />

            <label class="form-label">Mật khẩu</label>
            <input type="password" name="password" class="form-control" placeholder="••••••••" required />

            <button type="submit" class="btn-login">Đăng nhập</button>
        }

        <div class="divider">
            <div class="divider-line"></div>
            <span class="divider-text">Hệ thống quản trị nội bộ</span>
            <div class="divider-line"></div>
        </div>

        <p class="login-footer">© 2026 — Chỉ dành cho nhân viên được cấp quyền</p>
    </div>
</body>
</html>
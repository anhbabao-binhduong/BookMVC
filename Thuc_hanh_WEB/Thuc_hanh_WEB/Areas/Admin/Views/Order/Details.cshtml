@model Thuc_hanh_WEB.Models.Order
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var details = ViewBag.OrderDetails as IEnumerable<Thuc_hanh_WEB.Models.OrderDetail>;
    ViewBag.Title = "Chi tiết Đơn hàng #" + Model.OrderID;
}

<div class="row mt-4">
    <div class="col-12 d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0 text-primary fw-bold"><i class="fas fa-file-invoice me-2"></i>Hồ sơ Đơn hàng #@Model.OrderID</h3>
        <a href="@Url.Action("Index")" class="btn btn-light shadow-sm border"><i class="fas fa-arrow-left me-1"></i> Quay lại</a>
    </div>
</div>

<div class="row gx-4">
    <!-- Cột Thông tin Khách hàng -->
    <div class="col-xl-4 col-lg-5 mb-4">
        <div class="card shadow-sm border-0 h-100 rounded-3">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 text-dark fw-bold"><i class="fas fa-user-circle text-primary me-2"></i>Thông tin Khách hàng</h5>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item px-0 pt-0">
                        <small class="text-muted d-block mb-1">Họ và tên</small>
                        <span class="fw-semibold text-dark">@Model.FullName</span>
                    </li>
                    <li class="list-group-item px-0">
                        <small class="text-muted d-block mb-1">Số điện thoại</small>
                        <span class="text-dark"><i class="fas fa-phone-alt me-2 text-success opacity-75"></i>@Model.Phone</span>
                    </li>
                    <li class="list-group-item px-0">
                        <small class="text-muted d-block mb-1">Địa chỉ giao hàng</small>
                        <span class="text-dark"><i class="fas fa-map-marker-alt me-2 text-danger opacity-75"></i>@Model.Address</span>
                    </li>
                    <li class="list-group-item px-0 border-bottom-0 pb-0">
                        <small class="text-muted d-block mb-1">Ghi chú từ khách</small>
                        <div class="p-2 bg-light rounded text-dark small fst-italic">
                            @(string.IsNullOrEmpty(Model.Note) ? "Không có ghi chú." : Model.Note)
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Cột Thông tin Vận hành -->
    <div class="col-xl-8 col-lg-7 mb-4">
        <div class="card shadow-sm border-0 h-100 rounded-3">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 text-dark fw-bold"><i class="fas fa-clipboard-list text-primary me-2"></i>Thông tin Vận hành</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-sm-6 mb-3">
                        <small class="text-muted d-block mb-1">Thời gian đặt</small>
                        <span class="fw-semibold text-dark"><i class="far fa-calendar-alt me-2 text-primary opacity-75"></i>@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <small class="text-muted d-block mb-1">Hình thức Thanh toán</small>
                        <span class="fw-semibold text-dark">@Model.PaymentMethod</span>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <small class="text-muted d-block mb-1">Trạng thái Thanh toán</small>
                        @if (Model.PaymentStatus == "Paid" || Model.Status == "Completed")
                        {
                            <span class="badge bg-success"><i class="fas fa-check me-1"></i> Đã Thu Tiền</span>
                        }
                        else if (Model.Status == "Cancelled")
                        {
                            <span class="badge bg-danger"><i class="fas fa-ban me-1"></i> Đơn Đã Hủy</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary"><i class="fas fa-hourglass-half me-1"></i> Chưa Thanh Toán</span>
                        }
                    </div>
                    <div class="col-sm-6 mb-3">
                        <small class="text-muted d-block mb-1">Mã vận đơn (Tracking)</small>
                        <span class="fw-semibold text-dark user-select-all bg-light px-2 py-1 rounded border">@(string.IsNullOrEmpty(Model.ShippingCode) ? "Chưa cấp mã" : Model.ShippingCode)</span>
                    </div>
                </div>

                <hr class="my-3" />

                <!-- Cập nhật Trạng thái Form -->
                <form method="post" action="@Url.Action("UpdateStatus", "Order", new { area = "Admin" })" class="bg-light p-3 rounded border">
                    <input type="hidden" name="orderId" value="@Model.OrderID" />
                    <label class="form-label fw-bold text-dark mb-2">Cập nhật Trạng thái Xử lý</label>
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-white border-end-0"><i class="fas fa-sliders-h text-muted"></i></span>
                        <select name="status" class="form-select border-start-0 fw-semibold text-dark">
                            <option value="Pending" @(Model.Status == "Pending" ? "selected" : "")>Chờ xử lý (Pending)</option>
                            <option value="Shipping" @(Model.Status == "Shipping" ? "selected" : "")>Đang giao hàng (Shipping)</option>
                            <option value="Completed" @(Model.Status == "Completed" ? "selected" : "")>Đã hoàn thành (Completed)</option>
                            <option value="Cancelled" @(Model.Status == "Cancelled" ? "selected" : "")>Hủy bỏ (Cancelled)</option>
                        </select>
                        <button type="submit" class="btn btn-primary px-4 fw-bold"><i class="fas fa-save me-1"></i> Lưu trạng thái</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Giỏ hàng Chi tiết -->
<div class="row">
    <div class="col-12">
        <div class="card shadow-sm border-0 rounded-3 mb-4">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 text-dark fw-bold"><i class="fas fa-box text-primary me-2"></i>Danh sách Sản phẩm đã đặt</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Sản Phẩm</th>
                                <th class="text-center" style="width: 15%;">Đơn giá</th>
                                <th class="text-center" style="width: 15%;">Số lượng</th>
                                <th class="text-end pe-4" style="width: 20%;">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if(details != null && details.Any())
                            {
                                foreach (var item in details)
                                {
                                    <tr>
                                        <td class="ps-4 fw-semibold text-dark">
                                            <i class="fas fa-book text-muted me-2 opacity-50"></i> @(item.Book?.Title ?? "Sản phẩm không xác định")
                                        </td>
                                        <td class="text-center text-muted">@String.Format("{0:N0} đ", item.UnitPrice)</td>
                                        <td class="text-center fw-bold">x @item.Quantity</td>
                                        <td class="text-end pe-4 fw-bold text-danger">@String.Format("{0:N0} đ", item.Quantity * item.UnitPrice)</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="4" class="text-center text-muted py-4">Đơn hàng trống.</td></tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="3" class="text-end fw-bold text-dark pt-3 pb-3">Tổng cộng hóa đơn:</td>
                                <td class="text-end pe-4 fw-bold text-danger fs-5 pt-3 pb-3">@String.Format("{0:N0} đ", Model.TotalAmount)</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
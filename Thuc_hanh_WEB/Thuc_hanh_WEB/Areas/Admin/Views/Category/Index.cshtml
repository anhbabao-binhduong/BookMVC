@model IEnumerable<Thuc_hanh_WEB.Models.Category>
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Quản lý Danh mục";
}

<div class="row justify-content-center mt-3">
    <div class="col-lg-10">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                <h4 class="mb-0 text-primary"><i class="fas fa-folder-open me-2"></i>Danh sách Danh mục</h4>
                <a href="@Url.Action("Create")" class="btn btn-primary shadow-sm">
                    <i class="fas fa-plus me-1"></i> Thêm Danh mục
                </a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4" style="width: 10%;">ID</th>
                                <th style="width: 30%;">Tên danh mục</th>
                                <th style="width: 40%;">Mô tả</th>
                                <th class="text-center pe-4" style="width: 20%;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-secondary">#@item.CategoryID</td>
                                    <td class="fw-semibold text-dark">
                                        <span class="badge bg-secondary text-white bg-opacity-75 border border-secondary p-2">@item.CategoryName</span>
                                    </td>
                                    <td class="text-muted text-truncate" style="max-width: 250px;" title="@item.Description">
                                        @(string.IsNullOrEmpty(item.Description) ? "Không có mô tả" : item.Description)
                                    </td>
                                    <td class="text-center pe-4">
                                        <div class="btn-group shadow-sm" role="group">
                                            <a href="@Url.Action("Edit", new { id = item.CategoryID })" class="btn btn-sm btn-outline-primary" title="Chỉnh sửa"><i class="fas fa-edit"></i></a>
                                            <a href="@Url.Action("Delete", new { id = item.CategoryID })" class="btn btn-sm btn-outline-danger" title="Xóa"><i class="fas fa-trash-alt"></i></a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
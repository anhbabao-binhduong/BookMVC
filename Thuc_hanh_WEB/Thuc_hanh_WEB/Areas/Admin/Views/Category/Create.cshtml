@model Thuc_hanh_WEB.Models.Category
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Thêm Danh mục Mới";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow border-0 rounded-3">
            <div class="card-header bg-white border-bottom py-3">
                <h4 class="mb-0 text-primary"><i class="fas fa-folder-plus me-2"></i>Thêm Danh Mục Mới</h4>
            </div>
            <div class="card-body p-4">
                @using (Html.BeginForm("Create", "Category", new { area = "Admin" }, FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger border-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle me-1"></i> <strong>Cảnh báo lỗi:</strong>
                            @Html.ValidationSummary(false, "", new { @class = "mb-0 mt-2" })
                        </div>
                    }

                    <div class="mb-4">
                        @Html.LabelFor(m => m.CategoryName, "Tên danh mục", new { @class = "form-label fw-semibold" })
                        <div class="input-group input-group-lg shadow-sm">
                            <span class="input-group-text bg-light border-end-0"><i class="fas fa-tag text-muted"></i></span>
                            @Html.TextBoxFor(m => m.CategoryName, new { @class = "form-control border-start-0", placeholder = "Nhập tên danh mục (vd: Tiểu thuyết)...", required = "required" })
                        </div>
                        @Html.ValidationMessageFor(m => m.CategoryName, "", new { @class = "text-danger small mt-1 d-block" })
                    </div>

                    <div class="mb-4 mt-2">
                        @Html.LabelFor(m => m.Description, "Mô tả / Giới thiệu", new { @class = "form-label fw-semibold" })
                        @Html.TextAreaFor(m => m.Description, 4, 0, new { @class = "form-control shadow-sm", placeholder = "Nhập tóm tắt hoặc mô tả thể loại..." })
                        @Html.ValidationMessageFor(m => m.Description, "", new { @class = "text-danger small mt-1 d-block" })
                    </div>

                    <div class="d-flex justify-content-end gap-2 border-top pt-3 mt-4">
                        <a href="@Url.Action("Index", "Category", new { area = "Admin" })" class="btn btn-light border px-4">Quay lại</a>
                        <button type="submit" class="btn btn-primary px-4"><i class="fas fa-save me-1"></i> Lưu Danh Mục</button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
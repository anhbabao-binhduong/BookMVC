@model Thuc_hanh_WEB.Models.Coupon
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Thêm Mã giảm giá";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-10">
        <div class="card shadow border-0 rounded-3">
            <div class="card-header bg-white border-bottom py-3">
                <h4 class="mb-0 text-primary"><i class="fas fa-plus-circle me-2"></i>Thêm Mã giảm giá mới</h4>
            </div>
            <div class="card-body p-4">
                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()

                    if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger border-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle me-1"></i> <strong>Đã xảy ra lỗi:</strong>
                            @Html.ValidationSummary(false, "", new { @class = "mb-0 mt-2" })
                        </div>
                    }

                    <div class="row gx-5">
                        <!-- Cột Trái -->
                        <div class="col-md-6">
                            <div class="mb-3">
                                @Html.LabelFor(m => m.Code, "Mã Khuyến Mãi", new { @class = "form-label fw-semibold" })
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-light fw-bold text-muted">CODE</span>
                                    @Html.TextBoxFor(m => m.Code, new { @class = "form-control text-uppercase", placeholder = "VD: SUMMERFEVER2026" })
                                </div>
                                @Html.ValidationMessageFor(m => m.Code, "", new { @class = "text-danger small mt-1 d-block" })
                            </div>

                            <div class="row">
                                <div class="col-sm-6 mb-3">
                                    @Html.LabelFor(m => m.DiscountType, "Loại giảm giá", new { @class = "form-label fw-semibold" })
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light"><i class="fas fa-tags text-muted"></i></span>
                                        @Html.DropDownListFor(m => m.DiscountType, new SelectList(new[] { "Percent", "Fixed" }), new { @class = "form-select" })
                                    </div>
                                </div>
                                <div class="col-sm-6 mb-3">
                                    @Html.LabelFor(m => m.DiscountValue, "Giá trị", new { @class = "form-label fw-semibold" })
                                    <div class="input-group shadow-sm">
                                        @Html.TextBoxFor(m => m.DiscountValue, new { @class = "form-control", type = "number", step = "0.01", min = "0" })
                                        <span class="input-group-text bg-light fw-bold">VNĐ/%</span>
                                    </div>
                                    @Html.ValidationMessageFor(m => m.DiscountValue, "", new { @class = "text-danger small mt-1 d-block" })
                                </div>
                            </div>

                            <div class="mb-3">
                                @Html.LabelFor(m => m.MinOrderAmount, "Đơn hàng Tối thiểu áp dụng", new { @class = "form-label fw-semibold" })
                                <div class="input-group shadow-sm">
                                    @Html.TextBoxFor(m => m.MinOrderAmount, new { @class = "form-control", type = "number", step = "1000", min = "0" })
                                    <span class="input-group-text bg-light fw-bold">VNĐ</span>
                                </div>
                                <small class="text-muted mt-1 d-block">Để trống hoặc 0 nếu không yêu cầu giá trị tối thiểu.</small>
                            </div>
                        </div>

                        <!-- Cột Phải -->
                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-sm-6 mb-3">
                                    @Html.LabelFor(m => m.ExpiryDate, "Hạn sử dụng", new { @class = "form-label fw-semibold" })
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light"><i class="far fa-calendar-alt text-muted"></i></span>
                                        @Html.TextBoxFor(m => m.ExpiryDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                    </div>
                                </div>
                                <div class="col-sm-6 mb-3">
                                    @Html.LabelFor(m => m.MaxUsage, "Lượt sử dụng tối đa", new { @class = "form-label fw-semibold" })
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light"><i class="fas fa-users text-muted"></i></span>
                                        @Html.TextBoxFor(m => m.MaxUsage, new { @class = "form-control", type = "number", min = "1", placeholder = "VD: 100" })
                                    </div>
                                </div>
                            </div>

                            <div class="mb-3">
                                @Html.LabelFor(m => m.Description, "Mô tả Khuyến mãi", new { @class = "form-label fw-semibold" })
                                @Html.TextAreaFor(m => m.Description, new { @class = "form-control shadow-sm", rows = 3, placeholder = "Nhập mô tả cho khuyến mãi này để khách hàng dễ hiểu..." })
                            </div>

                            <div class="mb-3 p-3 bg-light rounded border">
                                <div class="form-check form-switch pt-1">
                                    @Html.CheckBoxFor(m => m.IsActive, new { @class = "form-check-input", role = "switch", id = "flexSwitchCheckDefault", @checked = "checked" })
                                    <label class="form-check-label fw-bold text-success ms-2" for="flexSwitchCheckDefault">Kích hoạt để sử dụng ngay</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 border-top pt-3 mt-3">
                        <a href="@Url.Action("Index")" class="btn btn-light border px-4">Hủy bỏ</a>
                        <button type="submit" class="btn btn-primary px-4"><i class="fas fa-save me-1"></i> Lưu Mã Mới</button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
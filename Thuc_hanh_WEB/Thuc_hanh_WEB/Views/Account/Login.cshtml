@{
    ViewBag.Title = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title – BookStore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />
    <link href="@Url.Content("~/Content/css/login.css")" rel="stylesheet" />
</head>
<body>

    <div class="page-wrap">

        <!-- LEFT PANEL -->
        <div class="left-panel">
            <div class="left-inner">
                <div class="left-logo">
                    <i class="fas fa-book-open"></i>
                </div>
                <h1>BookStore</h1>
                <p>Hàng ngàn đầu sách công nghệ &amp; kỹ năng đang chờ bạn khám phá.</p>
                <ul class="feature-list">
                    <li>
                        <span class="icon-badge"><i class="fas fa-shipping-fast"></i></span>
                        Giao hàng nhanh trong 24h
                    </li>
                    <li>
                        <span class="icon-badge"><i class="fas fa-shield-alt"></i></span>
                        Thanh toán bảo mật 100%
                    </li>
                    <li>
                        <span class="icon-badge"><i class="fas fa-sync-alt"></i></span>
                        Đổi trả dễ dàng trong 7 ngày
                    </li>
                    <li>
                        <span class="icon-badge"><i class="fas fa-tag"></i></span>
                        Ưu đãi độc quyền cho thành viên
                    </li>
                </ul>
            </div>
        </div>

        <!-- RIGHT PANEL -->
        <div class="right-panel">
            <div class="form-box">

                <h2>Chào mừng trở lại! 👋</h2>
                <p class="sub">Đăng nhập để tiếp tục mua sắm</p>

                @if (!string.IsNullOrEmpty(ViewBag.Error as string))
                {
                    <div class="alert-error">
                        <i class="fas fa-circle-exclamation"></i>
                        @ViewBag.Error
                    </div>
                }
                @if (TempData["ResetSuccess"] != null)
                {
                    <div class="alert-success">
                        <i class="fas fa-circle-check"></i>
                        @TempData["ResetSuccess"]
                    </div>
                }

                <form method="post" action="@Url.Action("Login","Account")" novalidate>
                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                    <label class="form-label">Email</label>
                    <div class="input-wrap">
                        <i class="fas fa-envelope input-icon"></i>
                        <input type="email" name="email" class="field"
                               placeholder="you@example.com" required autocomplete="email" />
                    </div>

                    <label class="form-label">Mật khẩu</label>
                    <div class="input-wrap" style="margin-bottom:10px">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" name="password" id="passwordInput"
                               class="field" placeholder="••••••••"
                               required autocomplete="current-password" />
                        <span class="toggle-pw" onclick="togglePassword()">
                            <i class="fas fa-eye" id="eyeIcon"></i>
                        </span>
                    </div>

                    <div class="row-between">
                        <a href="#" class="forgot-link" data-bs-toggle="modal" data-bs-target="#forgotModal">
                            <i class="fas fa-key me-1"></i> Quên mật khẩu?
                        </a>
                    </div>

                    <button type="submit" class="btn-login">
                        <i class="fas fa-right-to-bracket me-2"></i> Đăng nhập
                    </button>
                </form>

                <div class="divider">
                    <hr /><span>Chưa có tài khoản?</span><hr />
                </div>

                <a href="@Url.Action("Register","Account")" class="btn-register">
                    <i class="fas fa-user-plus me-2"></i> Tạo tài khoản mới – Miễn phí!
                </a>

                <a href="@Url.Action("Index","Home")" class="home-link">
                    <i class="fas fa-arrow-left me-1"></i> Quay về trang chủ
                </a>

            </div>
        </div>

    </div>


    <!-- MODAL QUÊN MẬT KHẨU -->
    <div class="modal fade" id="forgotModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-key me-2"></i> Quên mật khẩu
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Nhập email đã đăng ký. Chúng tôi sẽ gửi liên kết đặt lại mật khẩu cho bạn.</p>
                    <label class="form-label">Email</label>
                    <input type="email" id="forgotEmail" class="form-control"
                           placeholder="you@example.com" />
                    <div id="forgotMsg" class="mt-2" style="font-size:0.82rem; min-height:18px; font-weight:600;"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-primary btn-sm px-4" onclick="sendForgot()">
                        <i class="fas fa-paper-plane me-1"></i> Gửi yêu cầu
                    </button>
                </div>
            </div>
        </div>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    function togglePassword() {
        var input = document.getElementById("passwordInput");
        var icon  = document.getElementById("eyeIcon");
        if (input.type === "password") {
            input.type = "text";
            icon.classList.remove("fa-eye");
            icon.classList.add("fa-eye-slash");
        } else {
            input.type = "password";
            icon.classList.remove("fa-eye-slash");
            icon.classList.add("fa-eye");
        }
    }

    function sendForgot() {
        var email = document.getElementById("forgotEmail").value.trim();
        var msg   = document.getElementById("forgotMsg");

        if (!email || email.indexOf("@@") === -1) {
            msg.style.color = "#be123c";
            msg.textContent = "Vui lòng nhập email hợp lệ.";
            return;
        }

        msg.style.color = "#8a8a9a";
        msg.textContent = "Đang gửi...";

        fetch("/Account/ForgotPassword", {
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: "email=" + encodeURIComponent(email)
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                msg.style.color = "#15803d";
                msg.textContent = "✓ Email đặt lại mật khẩu đã được gửi. Vui lòng kiểm tra hộp thư.";
            } else {
                msg.style.color = "#be123c";
                msg.textContent = data.message || "Không tìm thấy email này.";
            }
        })
        .catch(function() {
            msg.style.color = "#be123c";
            msg.textContent = "Lỗi kết nối. Vui lòng thử lại.";
        });
    }
    </script>
</body>
</html>
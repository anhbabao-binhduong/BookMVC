@model RegisterViewModel
@{
    ViewBag.Title = "Đăng ký";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Đăng ký – BookStore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />
    <link href="@Url.Content("~/Content/css/register.css")" rel="stylesheet" />
</head>
<body>

    <div class="page-wrap">

        <!-- LEFT PANEL -->
        <div class="left-panel">
            <div class="left-inner">
                <div class="left-logo">
                    <i class="fas fa-book-open"></i>
                </div>
                <h1>BookStore</h1>
                <p>Tham gia cộng đồng hàng ngàn độc giả công nghệ ngay hôm nay!</p>
                <ul class="step-list">
                    <li>
                        <span class="step-num">1</span>
                        Điền thông tin tài khoản
                    </li>
                    <li>
                        <span class="step-num">2</span>
                        Xác thực email của bạn
                    </li>
                    <li>
                        <span class="step-num">3</span>
                        Bắt đầu mua sắm &amp; nhận ưu đãi!
                    </li>
                </ul>
            </div>
        </div>

        <!-- RIGHT PANEL -->
        <div class="right-panel">
            <div class="form-box">

                <h2>Tạo tài khoản mới 🎉</h2>
                <p class="sub">Đăng ký miễn phí, nhận ngay ưu đãi thành viên</p>

                @* THÔNG BÁO LỖI ĐĂNG KÝ THẤT BẠI *@
                @if (TempData["RegisterFail"] != null)
                {
                    <div class="alert-fail">
                        <i class="fas fa-circle-exclamation"></i>
                        @TempData["RegisterFail"]
                    </div>
                }

                @* CẢNH BÁO PHẢI NHẬP LẠI MẬT KHẨU *@
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert-warn">
                        <i class="fas fa-triangle-exclamation me-1"></i>
                        Vì lý do bảo mật, vui lòng nhập lại mật khẩu nếu form có lỗi.
                    </div>
                }

                <form method="post" action="@Url.Action("Register","Account")" novalidate>

                    <!-- HỌ TÊN -->
                    <div class="field-wrap">
                        <label class="form-label">Họ và tên</label>
                        <i class="fas fa-user input-icon"></i>
                        @Html.TextBoxFor(m => m.FullName, new { @class = "field", placeholder = "Nguyễn Văn A" })
                        @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "field-error" })
                    </div>

                    <!-- EMAIL & SĐT – 2 cột -->
                    <div class="grid-2">
                        <div class="field-wrap">
                            <label class="form-label">Email</label>
                            <i class="fas fa-envelope input-icon"></i>
                            @Html.TextBoxFor(m => m.Email, new { @class = "field", placeholder = "you@example.com" })
                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "field-error" })
                        </div>
                        <div class="field-wrap">
                            <label class="form-label">Số điện thoại</label>
                            <i class="fas fa-phone input-icon"></i>
                            @Html.TextBoxFor(m => m.Phone, new { @class = "field", placeholder = "09xxxxxxxx" })
                            @Html.ValidationMessageFor(m => m.Phone, "", new { @class = "field-error" })
                        </div>
                    </div>

                    <!-- MẬT KHẨU -->
                    <div class="field-wrap" style="margin-bottom:6px">
                        <label class="form-label">Mật khẩu</label>
                        <i class="fas fa-lock input-icon"></i>
                        @Html.PasswordFor(m => m.Password, new { @class = "field", id = "pwInput", placeholder = "Tối thiểu 8 ký tự", oninput = "checkStrength(this.value)" })
                        <span class="toggle-pw" onclick="togglePw('pwInput','eye1')">
                            <i class="fas fa-eye" id="eye1"></i>
                        </span>
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "field-error" })
                    </div>

                    <!-- STRENGTH BAR -->
                    <div class="strength-wrap">
                        <div class="strength-track">
                            <div class="strength-fill" id="strengthFill"></div>
                        </div>
                        <div class="strength-label" id="strengthLabel"></div>
                        <div class="hint">≥ 8 ký tự, gồm chữ hoa, chữ thường, số và ký tự đặc biệt</div>
                    </div>

                    <!-- XÁC NHẬN MẬT KHẨU -->
                    <div class="field-wrap" style="margin-bottom:4px">
                        <label class="form-label">Xác nhận mật khẩu</label>
                        <i class="fas fa-lock input-icon"></i>
                        @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "field", id = "pwConfirm", placeholder = "Nhập lại mật khẩu", oninput = "checkMatch()" })
                        <span class="toggle-pw" onclick="togglePw('pwConfirm','eye2')">
                            <i class="fas fa-eye" id="eye2"></i>
                        </span>
                        @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "field-error" })
                    </div>
                    <div class="match-msg" id="matchMsg"></div>

                    <button type="submit" class="btn-register">
                        <i class="fas fa-user-plus me-2"></i> Đăng ký ngay
                    </button>
                </form>

                <div class="divider">
                    <hr /><span>Đã có tài khoản?</span><hr />
                </div>

                <a href="@Url.Action("Login","Account")" class="btn-login-link">
                    <i class="fas fa-right-to-bracket me-2"></i> Đăng nhập
                </a>

                <a href="@Url.Action("Index","Home")" class="home-link">
                    <i class="fas fa-arrow-left me-1"></i> Quay về trang chủ
                </a>

            </div>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Auto focus vào field lỗi đầu tiên
        var firstErr = document.querySelector(".input-validation-error");
        if (firstErr) firstErr.focus();

        function togglePw(inputId, iconId) {
            var input = document.getElementById(inputId);
            var icon = document.getElementById(iconId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("fa-eye");
                icon.classList.add("fa-eye-slash");
            } else {
                input.type = "password";
                icon.classList.remove("fa-eye-slash");
                icon.classList.add("fa-eye");
            }
        }

        function checkStrength(val) {
            var fill = document.getElementById("strengthFill");
            var label = document.getElementById("strengthLabel");
            var score = 0;
            if (val.length >= 8) score++;
            if (/[A-Z]/.test(val)) score++;
            if (/[a-z]/.test(val)) score++;
            if (/\d/.test(val)) score++;
            if (/[^A-Za-z\d]/.test(val)) score++;

            var configs = [
                { pct: "0%", color: "transparent", text: "" },
                { pct: "20%", color: "#ef4444", text: "Rất yếu" },
                { pct: "40%", color: "#f97316", text: "Yếu" },
                { pct: "60%", color: "#eab308", text: "Trung bình" },
                { pct: "80%", color: "#22c55e", text: "Mạnh" },
                { pct: "100%", color: "#ff6b35", text: "Rất mạnh" }
            ];

            fill.style.width = configs[score].pct;
            fill.style.background = configs[score].color;
            label.textContent = configs[score].text;
            label.style.color = configs[score].color;
        }

        function checkMatch() {
            var p1 = document.getElementById("pwInput").value;
            var p2 = document.getElementById("pwConfirm").value;
            var msg = document.getElementById("matchMsg");
            if (p2.length === 0) { msg.textContent = ""; return; }
            if (p1 === p2) {
                msg.style.color = "#15803d";
                msg.textContent = "✓ Mật khẩu khớp";
            } else {
                msg.style.color = "#be123c";
                msg.textContent = "✗ Mật khẩu chưa khớp";
            }
        }
    </script>
</body>
</html>
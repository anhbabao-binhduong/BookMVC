@{
    ViewBag.Title = "Đặt lại mật khẩu";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Đặt lại mật khẩu - BookStore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            margin: 0;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .wrapper {
            width: 100%;
            max-width: 440px;
            padding: 16px;
        }

        .brand {
            text-align: center;
            margin-bottom: 28px;
        }

        .brand-icon {
            width: 64px;
            height: 64px;
            background: linear-gradient(135deg, #4f8ef7, #2563eb);
            border-radius: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 12px;
            box-shadow: 0 8px 24px rgba(79,142,247,0.35);
        }

            .brand-icon i {
                font-size: 28px;
                color: #fff;
            }

        .brand h1 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #fff;
            margin: 0;
        }

        .brand p {
            color: rgba(255,255,255,0.55);
            font-size: 0.875rem;
            margin: 4px 0 0;
        }

        .card-box {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 20px;
            padding: 36px 32px;
            box-shadow: 0 24px 64px rgba(0,0,0,0.4);
        }

            .card-box h2 {
                font-size: 1.2rem;
                font-weight: 700;
                color: #fff;
                margin-bottom: 6px;
                text-align: center;
            }

            .card-box .subtitle {
                text-align: center;
                color: rgba(255,255,255,0.45);
                font-size: 0.85rem;
                margin-bottom: 28px;
            }

        .form-label {
            color: rgba(255,255,255,0.75);
            font-size: 0.85rem;
            font-weight: 500;
            margin-bottom: 6px;
            display: block;
        }

        .input-group-custom {
            position: relative;
            margin-bottom: 18px;
        }

        .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,0.35);
            font-size: 0.9rem;
            z-index: 2;
            pointer-events: none;
        }

        .form-control-custom {
            width: 100%;
            padding: 12px 40px 12px 40px;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 10px;
            color: #fff;
            font-size: 0.95rem;
            transition: all 0.25s ease;
            outline: none;
        }

            .form-control-custom::placeholder {
                color: rgba(255,255,255,0.3);
            }

            .form-control-custom:focus {
                background: rgba(255,255,255,0.1);
                border-color: #4f8ef7;
                box-shadow: 0 0 0 3px rgba(79,142,247,0.2);
            }

        .toggle-password {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,0.35);
            cursor: pointer;
            font-size: 0.9rem;
            z-index: 2;
            transition: color 0.2s;
        }

            .toggle-password:hover {
                color: rgba(255,255,255,0.7);
            }

        .strength-bar-wrap {
            margin-top: -10px;
            margin-bottom: 16px;
        }

        .strength-track {
            height: 4px;
            background: rgba(255,255,255,0.1);
            border-radius: 4px;
            overflow: hidden;
        }

        .strength-fill {
            height: 100%;
            width: 0%;
            border-radius: 4px;
            transition: all 0.3s ease;
        }

        .strength-label {
            font-size: 0.75rem;
            margin-top: 4px;
        }

        .btn-submit {
            width: 100%;
            padding: 13px;
            background: linear-gradient(135deg, #4f8ef7, #2563eb);
            border: none;
            border-radius: 10px;
            color: #fff;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.25s ease;
            box-shadow: 0 4px 16px rgba(37,99,235,0.4);
            margin-top: 4px;
        }

            .btn-submit:hover {
                background: linear-gradient(135deg, #3b7de8, #1d4ed8);
                transform: translateY(-1px);
                box-shadow: 0 6px 20px rgba(37,99,235,0.5);
            }

            .btn-submit:active {
                transform: translateY(0);
            }

        .alert-error {
            background: rgba(239,68,68,0.25);
            border: 1px solid rgba(239,68,68,0.6);
            border-radius: 10px;
            color: #ffffff;
            font-weight: 500;
            padding: 11px 14px;
            font-size: 0.875rem;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .alert-success {
            background: rgba(34,197,94,0.25);
            border: 1px solid rgba(34,197,94,0.6);
            border-radius: 10px;
            color: #ffffff;
            font-weight: 500;
            padding: 11px 14px;
            font-size: 0.875rem;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .alert-invalid {
            background: rgba(234,179,8,0.12);
            border: 1px solid rgba(234,179,8,0.3);
            border-radius: 12px;
            color: #fde68a;
            padding: 20px 24px;
            text-align: center;
        }

            .alert-invalid i {
                font-size: 2rem;
                margin-bottom: 10px;
                display: block;
            }

            .alert-invalid h5 {
                font-weight: 700;
                margin-bottom: 6px;
            }

            .alert-invalid p {
                font-size: 0.875rem;
                color: rgba(253,230,138,0.7);
                margin: 0;
            }

        .back-link {
            display: block;
            text-align: center;
            margin-top: 20px;
            color: rgba(255,255,255,0.4);
            font-size: 0.82rem;
            text-decoration: none;
            transition: color 0.2s;
        }

            .back-link:hover {
                color: rgba(255,255,255,0.7);
            }
    </style>
</head>
<body>

    <div class="wrapper">

        <div class="brand">
            <div class="brand-icon">
                <i class="fas fa-book-open"></i>
            </div>
            <h1>BookStore</h1>
            <p>Kho sách công nghệ hàng đầu</p>
        </div>

        <div class="card-box">

            @if (ViewBag.InvalidToken == true)
            {
                <div class="alert-invalid">
                    <i class="fas fa-triangle-exclamation"></i>
                    <h5>Liên kết không hợp lệ</h5>
                    <p>Link đặt lại mật khẩu đã hết hạn hoặc không chính xác.<br />Vui lòng yêu cầu lại.</p>
                </div>
                <a href="@Url.Action("Login","Account")" class="btn-submit d-block text-center text-decoration-none mt-3"
                   style="line-height:1.8">
                    <i class="fas fa-arrow-left me-2"></i> Quay lại đăng nhập
                </a>
            }
            else
            {
                <h2><i class="fas fa-lock-open text-warning me-2"></i>Đặt lại mật khẩu</h2>
                <p class="subtitle">Nhập mật khẩu mới cho tài khoản của bạn</p>

                if (!string.IsNullOrEmpty(ViewBag.Error as string))
                {
                    <div class="alert-error">
                        <i class="fas fa-circle-exclamation"></i>
                        @ViewBag.Error
                    </div>
                }

                if (!string.IsNullOrEmpty(ViewBag.Success as string))
                {
                    <div class="alert-success">
                        <i class="fas fa-circle-check"></i>
                        @ViewBag.Success
                    </div>
                }

                <form method="post" action="@Url.Action("ResetPassword","Account")" novalidate>
                    <input type="hidden" name="token" value="@ViewBag.Token" />

                    <label class="form-label">Mật khẩu mới</label>
                    <div class="input-group-custom" style="margin-bottom:8px">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" name="newPassword" id="newPassword"
                               class="form-control-custom" placeholder="Tối thiểu 8 ký tự"
                               required oninput="checkStrength(this.value)" />
                        <span class="toggle-password" onclick="togglePass('newPassword','eye1')">
                            <i class="fas fa-eye" id="eye1"></i>
                        </span>
                    </div>

                    <div class="strength-bar-wrap">
                        <div class="strength-track">
                            <div class="strength-fill" id="strengthFill"></div>
                        </div>
                        <div class="strength-label" id="strengthLabel"></div>
                    </div>

                    <label class="form-label">Xác nhận mật khẩu</label>
                    <div class="input-group-custom">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" name="confirmPassword" id="confirmPassword"
                               class="form-control-custom" placeholder="Nhập lại mật khẩu"
                               required oninput="checkMatch()" />
                        <span class="toggle-password" onclick="togglePass('confirmPassword','eye2')">
                            <i class="fas fa-eye" id="eye2"></i>
                        </span>
                    </div>
                    <div id="matchMsg" style="font-size:0.78rem; margin-top:-12px; margin-bottom:16px; min-height:16px;"></div>

                    <button type="submit" class="btn-submit">
                        <i class="fas fa-check me-2"></i> Xác nhận đổi mật khẩu
                    </button>
                </form>
            }

        </div>

        <a href="@Url.Action("Login","Account")" class="back-link">
            <i class="fas fa-arrow-left me-1"></i> Quay lại đăng nhập
        </a>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function togglePass(inputId, iconId) {
            var input = document.getElementById(inputId);
            var icon = document.getElementById(iconId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("fa-eye");
                icon.classList.add("fa-eye-slash");
            } else {
                input.type = "password";
                icon.classList.remove("fa-eye-slash");
                icon.classList.add("fa-eye");
            }
        }

        function checkStrength(val) {
            var fill = document.getElementById("strengthFill");
            var label = document.getElementById("strengthLabel");
            var score = 0;

            if (val.length >= 8) score++;
            if (/[A-Z]/.test(val)) score++;
            if (/[a-z]/.test(val)) score++;
            if (/\d/.test(val)) score++;
            if (/[^A-Za-z\d]/.test(val)) score++;

            var configs = [
                { pct: "0%", color: "transparent", text: "" },
                { pct: "20%", color: "#ef4444", text: "Rất yếu" },
                { pct: "40%", color: "#f97316", text: "Yếu" },
                { pct: "60%", color: "#eab308", text: "Trung bình" },
                { pct: "80%", color: "#22c55e", text: "Mạnh" },
                { pct: "100%", color: "#4f8ef7", text: "Rất mạnh" }
            ];

            fill.style.width = configs[score].pct;
            fill.style.background = configs[score].color;
            label.textContent = configs[score].text;
            label.style.color = configs[score].color;
        }

        function checkMatch() {
            var p1 = document.getElementById("newPassword").value;
            var p2 = document.getElementById("confirmPassword").value;
            var msg = document.getElementById("matchMsg");

            if (p2.length === 0) { msg.textContent = ""; return; }

            if (p1 === p2) {
                msg.style.color = "#86efac";
                msg.textContent = "✓ Mật khẩu khớp";
            } else {
                msg.style.color = "#fca5a5";
                msg.textContent = "✗ Mật khẩu chưa khớp";
            }
        }
    </script>
</body>
</html>